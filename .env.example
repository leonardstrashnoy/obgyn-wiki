# OpenRouter API key — used for medical LLM subagents
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: default medical model on OpenRouter
# Options: meta-llama/llama-3.3-70b-instruct, mistralai/mistral-large-latest,
#          anthropic/claude-3.5-sonnet, google/gemini-1.5-pro, etc.
# For medical tasks, consider: perplexity/sonar-reasoning-pro (with citations) or
# any model you evaluate on USMLE benchmarks
DEFAULT_MEDICAL_MODEL=mistralai/mistral-large-latest

# PubMed / NCBI (no key needed for basic E-utilities)
# If you have an NCBI API key, set it for higher rate limits
NCBI_API_KEY=

# Wiki paths
WIKI_PATH=/home/leonard/Projects/obgyn-wiki/wiki
